{
  "manifest_version": 3,
  "name": "CSES Problem Tracker",
  "version": "1.0",
  "description": "Track and display the number of solved problems on CSES.fi",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://cses.fi/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://cses.fi/problemset/*"],
      "js": ["leetcode-mapping.js", "content.js"],
      "css": ["styles.css", "modern-styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CSES Problem Tracker"
 
  }
}
